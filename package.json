{
  "name": "claude-code-local-copy",
  "version": "0.1.0",
  "private": true,
  "description": "Local research copy of a Claude Code source snapshot.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "claude": "bin/claude-local.cjs",
    "claude-local": "bin/claude-local.cjs"
  },
  "scripts": {
    "build": "bun build ./src/entrypoints/cli.tsx --outdir ./dist --target bun",
    "start": "bun run ./src/entrypoints/cli.tsx",
    "start:dist": "bun ./dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
